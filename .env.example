# PostgreSQL connection string (Render בפרודקשן / npx prisma dev לוקאלית — ראו .env)
DATABASE_URL=

# openssl rand -base64 32 (או: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# מפתח Claude API מ-console.anthropic.com
ANTHROPIC_API_KEY=

# שירות ה-worker של NotebookLM
WORKER_URL=
WORKER_SECRET=

# מצב worker: dry_run (תוצרי דמה לבדיקות) או real (הפקה אמיתית)
WORKER_MODE=dry_run
